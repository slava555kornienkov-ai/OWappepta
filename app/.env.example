# ==========================================
# Open Waters - Environment Variables
# ==========================================
# Copy this file to .env and fill in your values

# --- Kimi Platform (OAuth Auth) ---
APP_ID=your_app_id
APP_SECRET=your_app_secret
VITE_APP_ID=your_app_id
VITE_KIMI_AUTH_URL=https://auth.kimi.com
KIMI_AUTH_URL=https://auth.kimi.com
KIMI_OPEN_URL=https://open.kimi.com
OWNER_UNION_ID=your_owner_union_id

# --- Database (MySQL / TiDB Cloud) ---
# Format: mysql://username:password@host:port/database
DATABASE_URL=mysql://user:password@host:port/dbname?ssl={"rejectUnauthorized":true}

# --- Telegram Bot (optional - for bot notifications) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# --- App URL (for production) ---
VITE_APP_URL=https://your-domain.com
